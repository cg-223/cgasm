# Memory can only be reserved by calling malloc.
# Addresses under &100 is considered registers, and can be safely used.
# Data between &100 and &1000 is the responsibility of malloc to do as it sees fit.
# Basic bump allocator.
# Pass: Requested length of allocation
# Recieve: Memory address of allocation (at &0)
'malloc:
    cmp &0 1
    eq &0 -1
    setif &0 0 &cmp
    retif &cmp
    eq &100 0
    callif 'malloc_init &cmp
    push &1
    set &1 &101
    add &101 &0
    set &&101 &0
    add &101 16
    set &0 &1
    add &0 16
    pop &1
        ret

'malloc_init:
    set &100 1
    set &101 2000

'start:
    print "enter file name to run"
    set &0 64
    call 'malloc
    inputstr &&0 64
    fileinfo &&0 &1
    eq &1 -1
    eq &cmp 0
    jif 'file_exists &cmp
    print "file does not exist"
    jmp 'start
'file_exists:
    set &2 &0
    set &0 &1
    call 'malloc
    readfile &&2 &&0
    load &&0
    jmp 'start
